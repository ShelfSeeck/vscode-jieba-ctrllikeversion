{
  "name": "jieba",
  "displayName": "Jieba",
  "description": "Jieba Chinese word segmenter for VSCode",
  "version": "0.3.12",
  "engines": {
    "vscode": "^1.104.0"
  },
  "publisher": "StephanosKomnenos",
  "homepage": "https://github.com/stephanoskomnenos/vscode-jieba",
  "repository": {
    "type": "git",
    "url": "https://github.com/stephanoskomnenos/vscode-jieba"
  },
  "icon": "jieba.png",
  "license": "MIT",
  "keywords": [
    "Chinese",
    "Segmentation",
    "中文",
    "中文分词"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "jieba.forwardWord",
        "key": "Shift+Alt+F"
      },
      {
        "command": "jieba.backwardWord",
        "key": "Shift+Alt+B"
      },
      {
        "command": "jieba.killWord",
        "key": "Shift+Alt+D"
      },
      {
        "command": "jieba.backwardKillWord",
        "key": "Shift+Alt+Backspace"
      },
      {
        "command": "jieba.selectWord",
        "key": "Shift+Alt+2"
      }
    ],
    "commands": [
      {
        "command": "jieba.forwardWord",
        "title": "Jieba: Forward Word"
      },
      {
        "command": "jieba.backwardWord",
        "title": "Jieba: Backward Word"
      },
      {
        "command": "jieba.forwardSelectWord",
        "title": "Jieba: Forward Select Word"
      },
      {
        "command": "jieba.backwardSelectWord",
        "title": "Jieba: Backward Select Word"
      },
      {
        "command": "jieba.killWord",
        "title": "Jieba: Kill Word"
      },
      {
        "command": "jieba.backwardKillWord",
        "title": "Jieba: Backward Kill Word"
      },
      {
        "command": "jieba.selectWord",
        "title": "Jieba: Select Word"
      }
    ],
    "configuration": {
      "title": "Jieba",
      "properties": {
        "jieba.segmenter": {
          "type": "string",
          "default": "jieba-wasm",
          "description": "Selects the segmenter engine for text segmentation.",
          "enum": [
            "jieba-wasm",
            "Intl.Segmenter"
          ],
          "enumDescriptions": [
            "Use Jieba segmenter (best for Chinese)",
            "Use Node's Intl.Segmenter (supports multiple languages, but has smaller dictionary)"
          ]
        },
        "jieba.intlSegmenterLocales": {
          "type": "array",
          "default": [
            "zh-CN"
          ],
          "description": "A list of language locales for the Intl.Segmenter. Only applies when 'Segmenter' is set to 'Intl.Segmenter'.",
          "items": {
            "type": "string"
          }
        },
        "jieba.enableOnDoubleClick": {
          "type": "boolean",
          "default": false,
          "description": "Enable selection on double click."
        },
        "jieba.clicksInterval": {
          "type": "number",
          "default": 500,
          "description": "The maximum interval in milliseconds between clicks to be considered a double click."
        },
        "jieba.triggerDelay": {
          "type": "number",
          "default": 150,
          "description": "The delay after triggering the selection, to prevent conflicting with normal selection."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "bun run compile && bun run lint",
    "lint": "eslint src --ext ts",
    "test": "bun ./out/test/runTest.js",
    "package": "bunx @vscode/vsce package",
    "publish": "bunx @vscode/vsce publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.3.3",
    "@types/vscode": "^1.104.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^9.35.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0"
  },
  "dependencies": {
    "jieba-wasm": "^2.4.0",
    "quick-lru": "^7.1.0"
  }
}
