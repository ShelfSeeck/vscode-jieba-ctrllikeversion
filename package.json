{
  "name": "jieba-ctrllikeversion",
  "displayName": "Jieba Ctrl-like Version",
  "description": "中文分词扩展，快捷键与英文体验统一（Ctrl+Left/Right/Backspace/Delete）。基于 vscode-jieba 改造。",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "ShelfSeeck",
  "homepage": "https://github.com/ShelfSeeck/vscode-jieba-ctrllikeversion",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShelfSeeck/vscode-jieba-ctrllikeversion"
  },
  "icon": "jieba.png",
  "license": "MIT",
  "keywords": [
    "Chinese",
    "Segmentation",
    "中文",
    "中文分词",
    "CJK"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "keybindings": [
      {
        "command": "cws.forwardWord",
        "key": "ctrl+right",
        "mac": "alt+right",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.backwardWord",
        "key": "ctrl+left",
        "mac": "alt+left",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.killWord",
        "key": "ctrl+delete",
        "mac": "alt+delete",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.backwardKillWord",
        "key": "ctrl+backspace",
        "mac": "alt+backspace",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.forwardSelectWord",
        "key": "ctrl+shift+right",
        "mac": "alt+shift+right",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.backwardSelectWord",
        "key": "ctrl+shift+left",
        "mac": "alt+shift+left",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "cws.selectWord",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "commands": [
      {
        "command": "cws.forwardWord",
        "title": "中文分词: 向后移动一个词"
      },
      {
        "command": "cws.backwardWord",
        "title": "中文分词: 向前移动一个词"
      },
      {
        "command": "cws.forwardSelectWord",
        "title": "中文分词: 向后选择扩展"
      },
      {
        "command": "cws.backwardSelectWord",
        "title": "中文分词: 向前选择扩展"
      },
      {
        "command": "cws.killWord",
        "title": "中文分词: 向后删除一个词"
      },
      {
        "command": "cws.backwardKillWord",
        "title": "中文分词: 向前删除一个词"
      },
      {
        "command": "cws.selectWord",
        "title": "中文分词: 选中当前词"
      }
    ],
    "configuration": {
      "title": "Chinese Word Segmentation",
      "properties": {
        "cws.segmenter": {
          "type": "string",
          "default": "jieba-wasm",
          "description": "分词引擎选择",
          "enum": [
            "jieba-wasm",
            "Intl.Segmenter"
          ],
          "enumDescriptions": [
            "jieba-wasm: 基于 jieba-rs 的 WebAssembly 实现，中文分词效果最佳",
            "Intl.Segmenter: Node.js 内置分词器，支持多语言但词典较小"
          ]
        },
        "cws.intlSegmenterLocales": {
          "type": "array",
          "default": [
            "zh-CN"
          ],
          "description": "Intl.Segmenter 的语言区域设置列表，仅当分词引擎为 Intl.Segmenter 时生效",
          "items": {
            "type": "string"
          }
        },
        "cws.enableOnDoubleClick": {
          "type": "boolean",
          "default": false,
          "description": "启用双击选中分词"
        },
        "cws.clicksInterval": {
          "type": "number",
          "default": 500,
          "description": "双击判定的时间间隔（毫秒）"
        },
        "cws.triggerDelay": {
          "type": "number",
          "default": 150,
          "description": "双击选中触发的延迟时间（毫秒），用于避免与普通选中冲突"
        },
        "cws.enableWordHighlight": {
          "type": "boolean",
          "default": true,
          "description": "启用中文分词词高亮（光标放在中文词上时高亮所有相同词）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^9.36.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.45.0"
  },
  "dependencies": {
    "jieba-wasm": "^2.4.0",
    "quick-lru": "^7.2.0"
  }
}